{
  "name": "feather-base",
  "version": "0.1.2",
  "description": "birds db with other features",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#logger": "./src/utils/logger.js",
    "#constants/*": "./src/constants/*",
    "#controllers/*": "./src/controllers/*",
    "#middlewares/*": "./src/middlewares/*",
    "#models/*": "./src/models/*",
    "#routes/*": "./src/routes/*",
    "#services/*": "./src/services/*",
    "#utils/*": "./src/utils/*",
    "#validators/*": "./src/validators/*",
    "#config": "./src/config.js"
  },
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:local": "nodemon index.js",
    "start:debug": "./run.local.sh",
    "dev": "concurrently \"./run.dev.sh\" \"cd web && pnpm dev\" --names backend,frontend --prefix-colors blue,magenta",
    "dev:backend": "./run.dev.sh",
    "dev:frontend": "cd web && pnpm dev",
    "lint:fix": "eslint 'index.js' 'src/**/*.js?(x)' --fix",
    "prepare": "husky",
    "build:FE": "cd web && npx pnpm@latest i && npx pnpm@latest build"
  },
  "keywords": [
    "birds",
    "database"
  ],
  "author": "Sagnik B",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^9.30.0",
    "@sentry/profiling-node": "^9.30.0",
    "chalk": "^5.4.1",
    "connect-timeout": "^1.9.0",
    "convict": "^6.2.4",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "mongoose": "^8.16.0",
    "nanoid": "^5.1.5",
    "node-cache": "^5.1.2",
    "serverless-http": "^4.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.29.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.29.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.10"
  }
}
