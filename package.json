{
  "name": "feather-base",
  "version": "0.1.3",
  "description": "Pokédex-style database and visual explorer of Indian bird species",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#logger": "./src/utils/logger.js",
    "#constants/*": "./src/constants/*",
    "#controllers/*": "./src/controllers/*",
    "#middlewares/*": "./src/middlewares/*",
    "#models/*": "./src/models/*",
    "#routes/*": "./src/routes/*",
    "#services/*": "./src/services/*",
    "#utils/*": "./src/utils/*",
    "#validators/*": "./src/validators/*",
    "#config": "./src/config.js"
  },
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev:BE": "node --env-file=.env --watch index.js",
    "dev:FE": "cd web && pnpm dev",
    "dev": "concurrently \"node --env-file=.env index.js\" \"cd web && pnpm dev\" --names backend,frontend --prefix-colors blue,magenta",
    "verify-birds": "node --env-file=.env src/scripts/verify-birds.js",
    "insert-birds": "node --env-file=.env src/scripts/insert-birds.js",
    "lint:fix": "eslint 'index.js' 'src/**/*.js?(x)' --fix",
    "prepare": "husky",
    "build:FE": "cd web && npx pnpm@latest i && npx pnpm@latest build",
    "test": "node --test --experimental-test-module-mocks src/tests/*.test.js"
  },
  "keywords": [
    "birds",
    "india",
    "database",
    "mongodb",
    "express",
    "vue"
  ],
  "author": "Sagnik B",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "connect-timeout": "^1.9.0",
    "convict": "^6.2.4",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "mongoose": "^8.16.0",
    "nanoid": "^5.1.5",
    "node-cache": "^5.1.2",
    "serverless-http": "^4.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.29.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7"
  }
}
